# =============================================================================
# CentraleSupélec Finance — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# Ne JAMAIS committer .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Sanity CMS
# https://sanity.io/manage → projet → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Token avec droits Editor (server-only — ne pas préfixer NEXT_PUBLIC_)
SANITY_API_TOKEN=

# -----------------------------------------------------------------------------
# Resend — envoi du formulaire de contact
# https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://csfinance.fr
